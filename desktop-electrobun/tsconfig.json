{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "lib": ["ESNext", "DOM"],
    "types": ["bun-types"],
    "outDir": "dist"
  },
  "include": ["src/**/*", "electrobun.config.ts"]
}

[32m+[m[32m    source,[m
[32m+[m[32m    /notify\.error\(\s*data\.error\b/,[m
[32m+[m[32m    "notify.error(data.error …) renders the error envelope object as a React child → React #31 (#5991)"[m
[32m+[m[32m  );[m
[32m+[m[32m});[m

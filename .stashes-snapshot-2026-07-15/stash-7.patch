[32m+[m[32m// Regression guard for #5991 — clicking "Update now" showed an "Internal Server[m
[32m+[m[32m// Error" screen (Minified React error #31). The handler POSTs /api/system/version[m
[32m+[m[32m// (a loopback-only auto-update endpoint) and, on a non-OK JSON response, did:[m
[32m+[m[32m//     notify.error(data.error || "Failed to start update.");[m
[32m+[m[32m// OmniRoute's error envelope is `{ error: { code, message, correlation_id } }`, so[m
[32m+[m[32m// `data.error` is an OBJECT. notify.error rendered that object as a React child →[m
[32m+[m[32m// React #31 crash. The fix funnels the body through extractApiErrorMessage() (the[m
[32m+[m[32m// same helper introduced in #5340) so a string always reaches the toast.[m
[32m+[m
[32m+[m[32mconst here = dirname(fileURLToPath(import.meta.url));[m
[32m+[m[32mconst source = readFileSync([m
[32m+[m[32m  resolve(here, "../../../src/app/(dashboard)/dashboard/HomePageClient.tsx"),[m
[32m+[m[32m  "utf8"[m
[32m+[m[32m);[m
[32m+[m
[32m+[m[32mtest("HomePageClient imports the safe API error extractor", () => {[m
[32m+[m[32m  assert.match([m
[32m+[m[32m    source,[m
[32m+[m[32m    /import\s*\{\s*extractApiErrorMessage\s*\}\s*from\s*["']@\/shared\/http\/apiErrorMessage["']/,[m
[32m+[m[32m    "HomePageClient must import extractApiErrorMessage to render API errors safely (#5991)"[m
[32m+[m[32m  );[m
[32m+[m[32m});[m
[32m+[m
[32m+[m[32mtest("the update-error handler funnels the body through extractApiErrorMessage (#5991)", () => {[m
[32m+[m[32m  // The update failure path must extract a string, not hand the raw envelope object[m
[32m+[m[32m  // (which triggers React #31) to notify.error.[m
[32m+[m[32m  assert.match([m
[32m+[m[32m    source,[m
[32m+[m[32m    /notify\.error\(\s*extractApiErrorMessage\(\s*data\s*,/,[m
[32m+[m[32m    "the update-error notify.error must use extractApiErrorMessage(data, …) (#5991)"[m
[32m+[m[32m  );[m
[32m+[m[32m});[m
[32m+[m
[32m+[m[32mtest("the update-error handler never passes the raw error object to notify.error (#5991)", () => {[m

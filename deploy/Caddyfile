:{$CADDY_PORT:20128} {
	# The scaled deployment runs full OmniRoute instances behind Caddy; route
	# both UI and API traffic to the same replica pool instead of a missing
	# single-node API service.
	reverse_proxy {$CADDY_UPSTREAMS:omniroute-1:3000 omniroute-2:3000 omniroute-3:3000} {
		lb_policy least_conn
		health_uri {$CADDY_HEALTH_URI:/v1/models}
		health_interval 10s
		health_timeout 5s
		header_up X-Forwarded-Proto {http.request.proto}
		transport http {
			keepalive off
		}
	}
}

:20128 {
  reverse_proxy /api/v1/* {
    to {$CADDY_API_UPSTREAM}
    transport http {
      keepalive off
    }
    health_uri /v1/models
    health_interval 10s
    health_timeout 5s
  }

  reverse_proxy / {
    to {$CADDY_UI_UPSTREAM}
    transport http {
      keepalive off
    }
    header_up X-Forwarded-Proto {http.request.proto}
    header_up X-Forwarded-Host {http.request.host}
    header_up X-Forwarded-For {http.request.remote}
  }
}

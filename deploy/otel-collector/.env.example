# =============================================================================
#  OmniRoute — OpenTelemetry Collector sidecar env vars — PR-010
# =============================================================================
#  Copy to `.env` next to this file and edit. `make up` will auto-load.
#
#  Required for the collector to start:
#    OTEL_AUTH_TOKEN — bearer token matching OmniRoute's OTEL_EXPORTER_OTLP_HEADERS
#
#  Required to enable a specific backend (set at least one):
#    JAEGER_ENDPOINT     — for Jaeger (default: jaeger:4317)
#    TEMPO_ENDPOINT      — for Grafana Tempo (default: http://tempo:4318)
#    HONEYCOMB_API_KEY   — for Honeycomb (also set HONEYCOMB_DATASET)
#    HONEYCOMB_DATASET   — for Honeycomb
#    DATADOG_API_KEY     — for Datadog
#    PROMETHEUS_REMOTE_WRITE_URL — for Prom remote-write
#
#  Optional tuning:
#    SAMPLING_PROBABILITY  — overrides tail_sampling baseline (0-100)
#    REDACT_HEADERS        — comma-separated additional headers to redact
#    LOG_LEVEL             — collector self-log level (debug|info|warn|error)
#    COLLECTOR_PORT        — OTLP HTTP port (default 4318)
#    OTEL_RESOURCE_ATTRIBUTES — resource attrs (e.g. deployment.environment=prod)
# =============================================================================

# --- Required: auth --------------------------------------------------------
OTEL_AUTH_TOKEN=changeme-otel-token
DEPLOYMENT_ENV=production

# --- Backends (uncomment + fill the ones you want) --------------------------
# JAEGER_ENDPOINT=jaeger.4317.observability.svc:4317
# TEMPO_ENDPOINT=https://tempo-us-central1.grafana.net:443
# HONEYCOMB_API_KEY=hcabc_xxx
# HONEYCOMB_DATASET=omniroute-prod
# DATADOG_API_KEY=dd_api_xxx
# DATADOG_SITE=datadoghq.com
# PROMETHEUS_REMOTE_WRITE_URL=http://prometheus.observability.svc:9090/api/v1/write

# --- Tuning ---------------------------------------------------------------
SAMPLING_PROBABILITY=10
REDACT_HEADERS=x-tenant-secret,x-custom-auth
LOG_LEVEL=info
COLLECTOR_PORT=4318

# --- Resource attributes passed to the collector --------------------------
OTEL_RESOURCE_ATTRIBUTES=service.namespace=omniroute,deployment.environment=production
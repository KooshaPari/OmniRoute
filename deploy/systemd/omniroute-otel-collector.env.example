# =============================================================================
#  OmniRoute — OpenTelemetry Collector environment
# =============================================================================
#  Copy to /etc/omniroute/otel.env on the host (chmod 0600, owned by
#  omniroute:omniroute) and edit before enabling the systemd unit. The unit
#  loads this file via `EnvironmentFile=`; absent values fall back to the
#  collector.yaml defaults.
# =============================================================================

# OTLP endpoint the OmniRoute runtime exports to (loopback when co-located).
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318

# OTLP headers — sent on every export call. Match the `bearertokenauth.token`
# configured in /etc/omniroute/otel-collector.yaml.
OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer%20changeme-otel-token

# Service identification (OTEL_RESOURCE_ATTRIBUTES).
OTEL_SERVICE_NAME=omniroute
OTEL_RESOURCE_ATTRIBUTES=service.namespace=gateway,deployment.environment=production

# Master switch — set to "false" to disable telemetry at the SDK level
# without touching the collector. The collector itself keeps running.
OTEL_SDK_DISABLED=false

# Sampling (root span sampling ratio). 1.0 = keep everything; lower for
# high-volume prod. The collector ALSO applies tail-sampling (see
# `tail_sampling` processor in collector.yaml).
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0

# Collector-internal — affects only the otelcol-contrib process.
OTEL_AUTH_TOKEN=changeme-otel-token
DEPLOYMENT_ENV=production

# Endpoint the OmniRoute runtime uses to PROBE the collector health
# (read by src/lib/observability/collectorHealth.ts).
OTEL_COLLECTOR_HEALTH_ENDPOINT=http://127.0.0.1:13133
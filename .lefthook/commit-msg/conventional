#!/usr/bin/env sh
# .lefthook/commit-msg/conventional — Conventional Commits format check.
#
# Invoked by lefthook's commit-msg scripts:convention entry (see lefthook.yml).
# lefthook v2.1.9 does NOT pass $1 (the message file path) to commands: or
# scripts: in a useful way. We work around this by having lefthook set
# LEFTHOOK_COMMIT_MSG_FILE — but v2.1.9 doesn't expose that env var either.
#
# So we read $1 if present, fall back to reading the .git/COMMIT_EDITMSG file
# (which is where git stores the in-progress commit message regardless of how
# it was provided). Either path is reliable for `git commit -m "..."`.

msg_file="${1:-$GIT_DIR/COMMIT_EDITMSG}"

[ -n "$msg_file" ] && [ -f "$msg_file" ] || {
  echo "commit-msg: no message file (looked for: '$msg_file')" >&2
  exit 2
}

msg=$(head -1 "$msg_file")

if ! echo "$msg" | grep -qE "^(feat|fix|chore|docs|refactor|test|perf|build|ci|style|revert)(\(.+\))?!?: .+"; then
  echo "ERROR: commit message must follow Conventional Commits format" >&2
  echo "  Got:      $msg" >&2
  echo "  Expected: <type>(<scope>)?!: <subject>" >&2
  echo "  Types:    feat | fix | chore | docs | refactor | test | perf | build | ci | style | revert" >&2
  exit 1
fi
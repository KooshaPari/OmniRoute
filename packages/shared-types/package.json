{
  "name": "@omniroute/shared-types",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Canonical Zod schemas for the argismonitor protocol (frontend + backend)",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsgo -b",
    "dev": "tsgo -b --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src tests",
    "lint:fix": "oxlint src tests --fix",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "oxlint": "^1.72.0",
    "@typescript/native-preview": "^7.0.0-dev.20260704.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.0"
  }
}

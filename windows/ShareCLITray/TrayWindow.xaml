<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ShareCLITray.TrayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="sharecli Dashboard"
    Width="600"
    Height="400"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <Grid Padding="12" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header: Health Status -->
        <StackPanel Grid.Row="0" Spacing="8">
            <TextBlock
                Text="sharecli Process Manager"
                Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock x:Name="HealthStatusText" Text="Checking health..." />
        </StackPanel>

        <!-- Process List -->
        <ScrollView Grid.Row="1">
            <DataGrid
                x:Name="ProcessGrid"
                AutoGenerateColumns="False"
                CanUserReorderColumns="False"
                CanUserResizeColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Header="PID"
                        Binding="{Binding pid}"
                        Width="80" />
                    <DataGridTextColumn
                        Header="Name"
                        Binding="{Binding name}"
                        Width="150" />
                    <DataGridTextColumn
                        Header="Memory (MB)"
                        Binding="{Binding memory_mb}"
                        Width="100" />
                    <DataGridTextColumn
                        Header="Project"
                        Binding="{Binding project}"
                        Width="150" />
                </DataGrid.Columns>
            </DataGrid>
        </ScrollView>

        <!-- Buttons -->
        <StackPanel
            Grid.Row="2"
            Orientation="Horizontal"
            Spacing="8"
            HorizontalAlignment="Right">
            <Button Content="Refresh" Click="OnRefreshClick" />
            <Button Content="Close" Click="OnCloseClick" />
        </StackPanel>
    </Grid>
</Window>

# .envrc — direnv fast-path for OmniRoute
# Auto-sourced by direnv(1) when entering the repo root.
# Keep this file idempotent and fast (target: <200ms cold).

# bun + node bins on PATH (no-op if already present)
export PATH="$HOME/.bun/bin:$PATH"

# omni marker (consumed by some recipes)
export OMNI_BOOTSTRAPPED=1

# hint to scripts that we are inside a dev shell (skip expensive prompts)
export OMNI_DEV_SHELL=1

# platform-aware shell hints (don't override user choice)
case "$OSTYPE" in
  darwin*) export OMNI_PLATFORM=macos ;;
  linux*)  export OMNI_PLATFORM=linux ;;
  msys*|cygwin*) export OMNI_PLATFORM=windows ;;
esac

# If a previous bootstrap wrote an env hint, source it too
if [ -f .omni-bootstrap/env.sh ]; then
  # shellcheck disable=SC1091
  source .omni-bootstrap/env.sh
fi
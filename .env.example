# OmniRoute v4 monorepo — environment contract
# Copy to .env and adjust values. Lines starting with # are commented out (off-by-default).

# ═══════════════════════════════════════════════════════════════════════════════
# 1. Core service ports
# ═══════════════════════════════════════════════════════════════════════════════

# SvelteKit dev server (apps/web)
PORT_WEB=5173

# Rust gateway (omniroute-server)
PORT_GATEWAY=20128

# Tauri 2 dev tools
PORT_TAURI_DEV=1420

# ═══════════════════════════════════════════════════════════════════════════════
# 2. Runtime mode
# ═══════════════════════════════════════════════════════════════════════════════

# dev | preview | production
NODE_ENV=development

# bun | node (used by concurrently to launch the gateway and web)
RUNTIME=bun

# Public URL the webview loads in production
PUBLIC_WEB_URL=http://localhost:5173
PUBLIC_GATEWAY_URL=http://127.0.0.1:20128

# ═══════════════════════════════════════════════════════════════════════════════
# 3. Auth (Phase 1 — placeholder values for dev)
# ═══════════════════════════════════════════════════════════════════════════════

# JWT signing secret for the dev session cookie
JWT_SECRET=dev-only-jwt-secret-CHANGE-ME-IN-PROD

# Initial admin password (bootstrap only)
INITIAL_PASSWORD=CHANGEME

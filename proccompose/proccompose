#!/usr/bin/env bash
# proccompose - the runner CLI for argismonitor v4 process composition.
# Reads proccompose.yaml in the current directory and executes the
# requested action across the desktop + Vercel frontends.
#
# Usage:
#   proccompose up                 # deploy + serve + expose + vercel env
#   proccompose down               # stop desktop services
#   proccompose status             # health snapshot (human-readable)
#   proccompose status-json        # structured JSON for monitoring/dashboards
#   proccompose status --json       # alias for status-json
#   proccompose cutover <pct>      # flip OMNI_WEB_STACK_ROLLOUT
#   proccompose url                # print current BFF URL
#   proccompose logs <service>     # tail a service log
#   proccompose validate            # dry-run validation
#   proccompose plan               # print the resolved execution plan

set -euo pipefail

resolve_yaml() {
  local symlink_dir
  local realpath_dir
  symlink_dir=$(cd "$(dirname "${BASH_SOURCE[0]}" 2>/dev/null)" 2>/dev/null && pwd)
  realpath_dir=$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null)")" 2>/dev/null && pwd)
  for d in "$symlink_dir" "$realpath_dir" .; do
    [[ -f "$d/proccompose.yaml" ]] && { echo "$d/proccompose.yaml"; return 0; }
  done
  return 1
}
SCRIPT_LIB_REAL="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null)")" 2>/dev/null && pwd)/lib"
. "$SCRIPT_LIB_REAL/mcp-transport.sh" 2>/dev/null || true
. "$SCRIPT_LIB_REAL/mcp-server.sh" 2>/dev/null || true
. "$SCRIPT_LIB_REAL/mcp-sse-transport.sh" 2>/dev/null || true
. "$SCRIPT_LIB_REAL/init.sh" 2>/dev/null || true
INIT_SCRIPT="$SCRIPT_LIB_REAL/init.sh"
SCRIPT_LIB_SYMLINK="$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd)/lib"
SCRIPT_LIB="${SCRIPT_LIB_REAL:-$SCRIPT_LIB_SYMLINK}"
. "$SCRIPT_LIB/release-state.sh"
. "$SCRIPT_LIB/workos-auth.sh"
YAML_FILE="${PROCCOMPOSE_FILE:-$(resolve_yaml || echo proccompose.yaml)}"
PHENO_BIN="${PHENO_BIN:-$HOME/bin/pheno}"
V4_DIR="${V4_DIR:-$(dirname "$(cd "$(dirname "$0")" && pwd)")}"

log() { printf "\033[1;36m[proccompose]\033[0m %s\n" "$*"; }
err() { printf "\033[1;31m[proccompose ERROR]\033[0m %s\n" "$*" >&2; }
ok()  { printf "\033[1;32m[proccompose OK]\033[0m %s\n" "$*"; }

if [[ ! -f "$YAML_FILE" ]]; then
  err "no $YAML_FILE found - copy proccompose.example.yaml and edit"
  exit 1
fi

# Tiny YAML parser (extracts: config.*, services.<name>.{host,run,supervisor,build}, etc.)
# We use yq if available, else python3 with a minimal yaml.
yaml() { python3 -c "import sys,yaml;d=yaml.safe_load(open('$YAML_FILE'));import json;print(json.dumps(d))"; }

resolve_bff_url() {
  # Best-effort: the desktop's Tailscale hostname + bff_port
  $PHENO_BIN status 2>/dev/null | head -3 || true
  local host=$($PHENO_BIN run "tailscale status --self --json 2>/dev/null | jq -r .Self.DNSName" 2>/dev/null | sed 's/\.$//' || echo "localhost")
  echo "http://$host:4322"
}

cmd_up() {
  log "bringing up the v4 stack on desktop + Vercel frontends..."
  log "step 1/4: deploy + build on desktop..."
  $PHENO_BIN scp-to "$V4_DIR/" "~/argismonitor-monorepo/" || {
    $PHENO_BIN run "git clone https://github.com/KooshaPari/OmniRoute.git ~/argismonitor-monorepo && cd ~/argismonitor-monorepo && git checkout $(yq '.config.v4_ref // \"origin/feat/v4-svelte-hono-monorepo\"' <$YAML_FILE 2>/dev/null || echo origin/feat/v4-svelte-hono-monorepo)"
  }
  $PHENO_BIN run "cd ~/argismonitor-monorepo && bun install"

  log "step 2/4: build web + bff + kbridge..."
  $PHENO_BIN run "cd ~/argismonitor-monorepo/apps/web && bun run build"
  $PHENO_BIN run "cd ~/argismonitor-monorepo/apps/bff && bun run build"
  $PHENO_BIN run "cd ~/argismonitor-monorepo/backend-rust && cargo build --release -p omniroute-server"

  log "step 3/4: install launchd supervisors on desktop..."
  $PHENO_BIN run "mkdir -p ~/Library/LaunchAgents $DATA_DIR 2>/dev/null || true"
  # BFF plist (minimal inline write)
  $PHENO_BIN run 'cat > ~/Library/LaunchAgents/online.phenotype.argismonitor.bff.plist <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>online.phenotype.argismonitor.bff</string>
  <key>ProgramArguments</key><array>
    <string>/bin/bash</string><string>-c</string><string>cd $HOME/argismonitor-monorepo/apps/bff && DATA_DIR=$HOME/.argismonitor PORT=4322 OMNIROUTE_GATEWAY_SOCKET=/var/run/argismonitor/gateway.sock exec bun run src/server.ts</string>
  </array>
  <key>WorkingDirectory</key><string>$HOME/argismonitor-monorepo/apps/bff</string>
  <key>RunAtLoad</key><true/><key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>$HOME/.argismonitor/bff.launchd.log</string>
  <key>StandardErrorPath</key><string>$HOME/.argismonitor/bff.launchd.err</string>
</dict></plist>
EOF'
  $PHENO_BIN run "launchctl load ~/Library/LaunchAgents/online.phenotype.argismonitor.bff.plist 2>/dev/null || true"

  log "step 4/4: expose via Tailscale Funnel + update Vercel envs..."
  $PHENO_BIN run "tailscale funnel --bg --bg-local-allow-multiple-clients 4322"
  sleep 2
  BFF_URL=$($PHENO_BIN run "tailscale status --self --json | jq -r .Self.DNSName" | sed 's/\.$//')
  NEXTJS_URL=$($PHENO_BIN run "tailscale status --self --json | jq -r .Self.DNSName" | sed 's/\.$//')
  echo "$BFF_URL" > .argis-bff-url
  for proj in argismonitor-homepage argismonitor-app argismonitor-docs; do
    log "  -> $proj (vercel env update)"
    vercel env rm OMNI_BFF_URL production --yes --scope $proj >/dev/null 2>&1 || true
    echo "https://$BFF_URL:4322" | vercel env add OMNI_BFF_URL production --scope $proj >/dev/null
    vercel env rm NEXTJS_UPSTREAM production --yes --scope $proj >/dev/null 2>&1 || true
    echo "https://$BFF_URL:20128" | vercel env add NEXTJS_UPSTREAM production --scope $proj >/dev/null
    vercel env rm OMNI_WEB_STACK production --yes --scope $proj >/dev/null 2>&1 || true
    echo "svelte" | vercel env add OMNI_WEB_STACK production --scope $proj >/dev/null
    vercel env rm OMNI_WEB_STACK_ROLLOUT production --yes --scope $proj >/dev/null 2>&1 || true
    echo "1" | vercel env add OMNI_WEB_STACK_ROLLOUT production --scope $proj >/dev/null
  done
  ok "stack up - BFF URL: https://$BFF_URL:4322 (rollout=1%)"
}

cmd_down() {
  log "stopping desktop services..."
  $PHENO_BIN run "launchctl unload ~/Library/LaunchAgents/online.phenotype.argismonitor.bff.plist 2>/dev/null || true"
  $PHENO_BIN run "launchctl unload ~/Library/LaunchAgents/online.phenotype.argismonitor.gateway.plist 2>/dev/null || true"
  ok "stopped"
}

cmd_status() {
  if [[ "${1:-}" == "--json" ]]; then
    shift
    cmd_status_json
    return $?
  fi
  log "health snapshot:"
  BFF_URL=$($PHENO_BIN run "tailscale status --self --json" 2>/dev/null | jq -r .Self.DNSName | sed 's/\.$//' || echo "localhost")
  for s in 4322 20128; do
    if $PHENO_BIN run "curl -fsS --max-time 3 http://localhost:$s/healthz" 2>/dev/null >/dev/null; then
      ok ":$s responding"
    else
      err ":$s down"
    fi
  done
  $PHENO_BIN run "launchctl list | grep -E 'argismonitor|bff|gateway' || echo 'no supervisor services'"
}

cmd_cutover() {
  local pct="${1:-1}"
  log "setting OMNI_WEB_STACK_ROLLOUT=$pct% in all Vercel prod envs..."
  for proj in argismonitor-homepage argismonitor-app argismonitor-docs; do
    vercel env rm OMNI_WEB_STACK_ROLLOUT production --yes --scope $proj >/dev/null 2>&1 || true
    echo "$pct" | vercel env add OMNI_WEB_STACK_ROLLOUT production --scope $proj >/dev/null
  done
  ok "rollout $pct% applied"
}

cmd_url() {
  cat .argis-bff-url 2>/dev/null || resolve_bff_url
}

cmd_logs() {
  local svc="${1:-bff}"
  case "$svc" in
    bff)   $PHENO_BIN run "tail -f \$HOME/.argismonitor/bff.log" ;;
    gw|gateway) $PHENO_BIN run "tail -f \$HOME/.argismonitor/gateway.log" ;;
    next|nextjs) $PHENO_BIN run "tail -f \$HOME/.argismonitor/nextjs.log" ;;
    *) err "usage: proccompose logs [bff|gateway|nextjs]"; exit 1 ;;
  esac
}

cmd_validate() {
  log "validating $YAML_FILE..."
  python3 -c "import yaml; d=yaml.safe_load(open('$YAML_FILE')); print('services:', list(d.get('services', {}).keys())); print('vercel_projects:', [p['name'] for p in d.get('vercel_projects', [])])"
  ok "schema valid"
}

cmd_plan() {
  log "execution plan:"
  python3 -c "
import yaml
d = yaml.safe_load(open('$YAML_FILE'))
print('config:', d.get('config'))
print('services:')
for n, s in d.get('services', {}).items():
  print(f'  {n}  host={s.get(\"host\")}  cmd={s.get(\"run\", {}).get(\"cmd\")}')
print('vercel_projects:', [p['name'] for p in d.get('vercel_projects', [])])
print('cutover phases:', [c['pct'] for c in d.get('cutover', [])])
"
}


cmd_doctor() {
  log "checking prerequisites for argismonitor v4 stack..."
  local fail=0
  log "[1/6] pheno-compute-layer CLI (~/bin/pheno)..."
  if command -v pheno >/dev/null 2>&1 || [[ -x "$HOME/bin/pheno" ]]; then
    ok "pheno present: $(command -v pheno || echo "$HOME/bin/pheno")"
  else
    err "pheno missing - install via pheno-compute-layer"
    fail=1
  fi

  log "[2/6] Tailscale on PATH..."
  if command -v tailscale >/dev/null 2>&1; then
    ok "tailscale present: $(command -v tailscale)"
  else
    err "tailscale missing"
    fail=1
  fi

  log "[3/6] Tailscale running on desktop..."
  if [[ -x "$HOME/bin/pheno" ]]; then
    if "$HOME/bin/pheno" ts 2>&1 | head -1 | grep -q "100\."; then
      ok "desktop on Tailscale"
    else
      err "desktop Tailscale not up - run 'pheno ts' on desktop"
      fail=1
    fi
  fi

  log "[4/6] vercel CLI on PATH..."
  if command -v vercel >/dev/null 2>&1; then
    ok "vercel present: $(command -v vercel)"
  else
    err "vercel missing - install via 'npm i -g vercel'"
    fail=1
  fi

  log "[5/6] proccompose.yaml valid..."
  if bash -n "$0" 2>/dev/null; then
    if [[ -f "$YAML_FILE" ]]; then
      python3 -c "import yaml; d=yaml.safe_load(open('$YAML_FILE')); assert 'services' in d" && ok "valid: 4 services declared" || err "invalid: missing 'services' key"
    else
      err "missing - copy proccompose.example.yaml to ./proccompose.yaml"
      fail=1
    fi
  fi

  log "[6/6] yq on PATH (for runtime config var expansion)..."
  if command -v yq >/dev/null 2>&1; then
    ok "yq present"
  else
    err "yq missing - install via 'brew install yq'"
    fail=1
  fi

  if (( fail == 0 )); then
    ok "all prerequisites met - safe to run 'proccompose up'"
  else
    err "$fail prereq(s) missing - see above"
    exit 1
  fi
}

cmd_status_json() {
  # Structured status for monitoring/dashboards. Probes actual services and
  # reports machine-readable JSON. Excludes the human-readable cmd_status.
  local bff_url
  bff_url=$($PHENO_BIN run "tailscale status --self --json" 2>/dev/null | jq -r .Self.DNSName 2>/dev/null | sed "s/\\.\$//" || echo "localhost")
  local services_json="{"
  local first=1
  for port in 4322 20128; do
    local status="down" latency_ms="null"
    local start_ms=$(($(date +%s%N 2>/dev/null || date +%s) / 1000000))
    if $PHENO_BIN run "curl -fsS --max-time 3 http://localhost:$port/healthz" >/dev/null 2>&1; then
      status="up"
      local end_ms=$(($(date +%s%N 2>/dev/null || date +%s) / 1000000))
      latency_ms=$((end_ms - start_ms))
    fi
    local svc_name
    if [[ $port == 4322 ]]; then svc_name="bff"; else svc_name="nextjs"; fi
    if [[ $first -eq 0 ]]; then services_json+=","; fi
    first=0
    services_json+="\"${svc_name}\": {\"port\": $port, \"status\": \"${status}\", \"latency_ms\": ${latency_ms}}"
  done
  services_json+="}"

  local release_count=0
  if [[ -d "${RELEASE_DIR:-$HOME/.argismonitor/releases}" ]]; then
    release_count=$(ls -1 "${RELEASE_DIR:-$HOME/.argismonitor/releases}"/*.json 2>/dev/null | wc -l | tr -d " ")
  fi

  local last_sha="none"
  if [[ -n "${LAST_DEPLOY:-}" && -f "$LAST_DEPLOY" ]]; then
    last_sha=$(cat "$LAST_DEPLOY" 2>/dev/null | tr -d "\n" || echo "none")
  fi

  local lock_held="false"
  if [[ -n "${LOCK_FILE:-}" && -e "$LOCK_FILE" ]]; then
    lock_held="true"
  fi

  cat <<JSON
{
  "ts": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "yaml_file": "$YAML_FILE",
  "bff_host": "$bff_url",
  "services": $services_json,
  "release_count": $release_count,
  "last_deploy_sha": "$last_sha",
  "deploy_lock_held": $lock_held
}
JSON
}

cmd_dry_run() {
  log "dry-run: full execution graph for $YAML_FILE"
  echo ""
  echo "  (no commands will be executed; just the plan)"
  echo ""

  python3 <<PYTHON
import yaml
d = yaml.safe_load(open("$YAML_FILE"))
cfg = d.get('config', {})
print("  config:")
for k, v in cfg.items():
    print(f"    {k:14s} = {v}")
print()
print("  services (executed in dependency order):")
for n, s in d.get('services', {}).items():
  host = s.get('host', '?')
  cmd = s.get('run', {}).get('cmd', '?')
  deps = s.get('run', {}).get('depends_on', [])
  sup = 'launchd' if s.get('supervisor', {}).get('type') == 'launchd' else '(none)'
  print(f"    [{host:8s}] {n}")
  print(f"               cmd: {cmd}")
  print(f"               supervisor: {sup}")
  if deps:
    print(f"               depends_on: {', '.join(deps)}")
print()
print("  vercel_projects (env wired in declaration order):")
for p in d.get('vercel_projects', []):
  print(f"    {p['name']}: OMNI_BFF_URL, NEXTJS_UPSTREAM, OMNI_WEB_STACK, OMNI_WEB_STACK_ROLLOUT")
print()
print("  cutover phases (1 -> 10 -> 50 -> 100, gated by SLO):")
for c in d.get('cutover', []):
  print(f"    {c['pct']:>3d}% for {c['duration_hours']:>3d}h, success: {', '.join(c['success_criteria'])}")
print()
print("  monitor:")
m = d.get('monitor', {})
print(f"    SLO p95 < {m.get('slo', {}).get('p95_latency_ms', '?')}ms, error_rate < {m.get('slo', {}).get('error_rate_max', '?')}")
print(f"    alert: {m.get('alert', {}).get('on_breach', '?')}")
PYTHON
  echo ""
  log "to execute this plan for real, run:  proccompose up"
  log "to roll back, run:              proccompose cutover 0  (or 'proccompose rollback')"
}

cmd_ci() {
  log "CI mode: run a full stack in this sandbox using a fake desktop."
  log "This is for the GitHub Actions workflow + local dev iterations."
  log "All Tailscale/pheno operations are replaced with local bash."
  log ""
  # Bootstrap a fake data dir
  local fake_data="$HOME/.argismonitor.ci"
  mkdir -p "$fake_data"
  # Start a fake BFF on the configured port (assumes web + bff + kbridge are built)
  if [[ ! -f "$V4_DIR/apps/bff/dist/index.js" ]]; then
    log "BFF not built - run 'bun run build' in $V4_DIR/apps/bff first"
    return 1
  fi
  log "starting fake-BFF on :$bff_port (data: $fake_data)..."
  cd "$V4_DIR/apps/bff"
  DATA_DIR=$fake_data PORT=$bff_port OMNIROUTE_GATEWAY_SOCKET=$fake_data/gateway.sock nohup bun run dist/index.js > "$fake_data/bff.log" 2>&1 &
  echo $! > "$fake_data/bff.pid"
  sleep 2
  log "verifying fake-BFF health..."
  if curl -fsS --max-time 3 "http://localhost:$bff_port/healthz" >/dev/null; then
    ok "fake-BFF healthy on :$bff_port"
  else
    err "fake-BFF did not start - check $fake_data/bff.log"
    return 1
  fi
  log "running proccompose tests against fake-BFF..."
  cd "$V4_DIR/proccompose"
  bash tests/proccompose.test.sh
  log "stopping fake-BFF..."
  kill "$(cat $fake_data/bff.pid 2>/dev/null)" 2>/dev/null || true
  ok "ci mode complete"
}

cmd_watch() {
  local svc="${1:-bff}"
  cmd_logs "$svc"
}

cmd_deploy() {
  local ref="${1:-origin/feat/v4-svelte-hono-monorepo}"
  local slot="${PROCCOMPOSE_SLOT:-dev}"
  log "deploying ref=$ref to slot=$slot on desktop (atomic + idempotent)..."

  # Pre-deploy verifier gate (Slice B+).
  # Refuse to build/restart services unless the test suite passes.
  # Opt-out: PROCCOMPOSE_SKIP_TESTS=1 (for emergencies only; logged as a warning).
  if [[ "${PROCCOMPOSE_SKIP_TESTS:-0}" != "1" ]]; then
    log "running pre-deploy verifier (cmd_test)..."
    if ! cmd_test; then
      err "pre-deploy test gate FAILED - refusing to deploy"
      err "bypass with PROCCOMPOSE_SKIP_TESTS=1 (use sparingly)"
      return 1
    fi
  else
    log "PROCCOMPOSE_SKIP_TESTS=1 - skipping pre-deploy test gate (NOT recommended)"
  fi

  # Acquire deployment lock (prevents concurrent deploys)
  local lockfile="$HOME/.argismonitor/.lock.deploy.$slot"
  # Portable mkdir-based lock (flock is util-linux only)
  if ! mkdir "$lockfile.lock" 2>/dev/null; then
    err "another deploy is in progress for slot=$slot"
    return 1
  fi
  trap "rmdir \"$lockfile.lock\" 2>/dev/null" EXIT

  # Auth check
  if ! workos_authenticated; then
    log "WorkOS auth not configured - using dev mode (no prod releases)"
    if [[ "$slot" == "prod" ]]; then
      err "prod releases require WorkOS auth - set WORKOS_API_KEY + WORKOS_CLIENT_ID"
      return 1
    fi
  fi

  # Detect pre-existing deploy
  local prev_version
  prev_version=$(current_release "$slot" | python3 -c "import sys,json; print(json.load(sys.stdin).get('version',''))" 2>/dev/null || echo "")

  # Deploy via scp-to + run-the-services
  local new_version
  new_version="v4-$(date -u +%Y%m%dT%H%M%SZ)-$(echo $ref | tr / - | head -c 20 | tr -d /)"
  log "syncing v4 monorepo to desktop (ref: $ref)..."
  $PHENO_BIN scp-to "$V4_DIR/" "~/argismonitor-monorepo/" || {
    $PHENO_BIN run "git clone https://github.com/KooshaPari/OmniRoute.git ~/argismonitor-monorepo && cd ~/argismonitor-monorepo && git checkout $ref"
  }
  $PHENO_BIN run "cd ~/argismonitor-monorepo && git checkout $ref && git pull --ff-only"
  log "building web + bff + kbridge on desktop..."
  $PHENO_BIN run "cd ~/argismonitor-monorepo && bun install"
  $PHENO_BIN run "cd ~/argismonitor-monorepo/apps/web && bun run build"
  $PHENO_BIN run "cd ~/argismonitor-monorepo/apps/bff && bun run build"
  $PHENO_BIN run "cd ~/argismonitor-monorepo/backend-rust && cargo build --release -p omniroute-server"
  log "restarting services to pick up new build..."
  $PHENO_BIN run "launchctl kickstart -k gui/$(id -u)/online.phenotype.argismonitor.bff 2>/dev/null || true"
  $PHENO_BIN run "launchctl kickstart -k gui/$(id -u)/online.phenotype.argismonitor.gateway 2>/dev/null || true"
  sleep 2

  # Health check
  if ! $PHENO_BIN run "curl -fsS --max-time 3 http://localhost:4322/healthz" >/dev/null 2>&1; then
    err "BFF healthz failed - rolling back"
    cmd_rollback "$slot"
    return 1
  fi

  # Record the release
  local file
  file=$(record_release "$slot" "$ref" "$new_version")
  ok "deploy slot=$slot version=$new_version ref=$ref"
  log "rollback safety: $proccompose rollback $slot"
  log "previous release was: ${prev_version:-<none>}"
}

cmd_release() {
  local ref="${1:-origin/feat/v4-svelte-hono-monorepo}"
  local slot="${PROCCOMPOSE_SLOT:-dev}"
  local pct="${2:-1}"
  log "release: deploy + cutover + announce in one shot..."
  # cmd_deploy already runs the pre-deploy test gate; no need to duplicate here
  cmd_deploy "$ref" || { err "deploy failed - aborting release"; return 1; }
  cmd_cutover "$pct" || { err "cutover failed - deploy is live but traffic unchanged"; return 1; }
  ok "released $ref to slot=$slot at rollout=${pct}%"
}

cmd_rollback() {
  local slot="${1:-dev}"
  rollback_release "$slot"
  log "restarting services to pick up rolled-back build..."
  $PHENO_BIN run "cd ~/argismonitor-monorepo && git checkout $(current_release $slot | python3 -c "import sys,json; print(json.load(sys.stdin).get('ref',''))")"
  $PHENO_BIN run "cd ~/argismonitor-monorepo && git pull --ff-only"
  $PHENO_BIN run "cd ~/argismonitor-monorepo/apps/bff && bun run build"
  $PHENO_BIN run "cd ~/argismonitor-monorepo/backend-rust && cargo build --release -p omniroute-server"
  $PHENO_BIN run "launchctl kickstart -k gui/$(id -u)/online.phenotype.argismonitor.bff 2>/dev/null || true"
  $PHENO_BIN run "launchctl kickstart -k gui/$(id -u)/online.phenotype.argismonitor.gateway 2>/dev/null || true"
  ok "rolled back slot=$slot"
}

cmd_releases() {
  local slot="${1:-dev}"
  log "release history for slot=$slot:"
  list_releases "$slot"
}

cmd_lock() {
  local slot="${1:-dev}"
  local lockfile="$HOME/.argismonitor/.lock.deploy.$slot"
  if ! mkdir "$lockfile.lock" 2>/dev/null; then
    err "slot=$slot is already locked - another deploy is in progress"
    return 1
  fi
  echo "slot=$slot locked (PID=$$). run 'proccompose unlock $slot' to release."
  sleep infinity &
  wait
}

cmd_matrix() {
  local action="${1:-status}"
  shift 2>/dev/null || true
  case "$action" in
    canary)
      # proccompose matrix canary <pct>  - traffic-shift <pct>% to a separate
      # Vercel canary project (argismonitor-app-canary). The main
      # argismonitor-app stays on 0% canary; only the canary project gets
      # traffic. The Vercel edge can then split by subdomain or query.
      local pct="${1:-10}"
      cmd_matrix_canary "$pct"
      ;;
    full|rollout)
      # proccompose matrix full  - tear down canary, roll main to 100%
      log "matrix full: tearing down canary, rolling main to 100%"
      cmd_matrix_canary_teardown
      cmd_cutover 100
      ;;
    abort|teardown)
      # proccompose matrix abort - tear down canary without bumping main
      log "matrix abort: tearing down canary, no main roll"
      cmd_matrix_canary_teardown
      cmd_cutover 0
      ;;
    status)
      cmd_matrix_status
      ;;
    deploy|release|rollback)
      # Slot dispatcher - run the same action across dev + staging + prod
      log "matrix $action on all configured slots..."
      for slot in dev staging prod; do
        log "  slot=$slot"
        PROCCOMPOSE_SLOT="$slot" "$@"
      done
      ;;
    *)
      err "matrix action '$action' not implemented - use: status | deploy | release | rollback | canary <pct> | full | abort"
      return 1
      ;;
  esac
}

# matrix canary helpers (kept here so they share cmd_matrix's lifecycle)
cmd_matrix_canary() {
  local pct="${1:-10}"
  [[ "$pct" =~ ^[0-9]+$ ]] || { err "canary pct must be an integer"; return 1; }
  [[ "$pct" -ge 1 && "$pct" -le 99 ]] || { err "canary pct must be 1..99"; return 1; }
  log "spinning up Vercel canary at $pct% traffic..."
  # Deploy a preview build to argismonitor-app-canary (separate Vercel project)
  vercel link --scope argismonitor-app-canary --yes >/dev/null 2>&1 || true
  vercel deploy --prod --yes --scope argismonitor-app-canary >/dev/null 2>&1
  # Update canary env so the BFF/edge knows to route <pct>% to the canary
  for proj in argismonitor-app-canary argismonitor-app; do
    vercel env rm OMNI_CANARY_PCT production --yes --scope $proj >/dev/null 2>&1 || true
    echo "$pct" | vercel env add OMNI_CANARY_PCT production --scope $proj >/dev/null
  done
  $PHENO_BIN run "mkdir -p ${DATA_DIR} && cat > ${DATA_DIR}/matrix-state.json <<EOF
{\"canary_pct\":$pct,\"main_pct\":$((100-pct)),\"ts\":$(date +%s),\"action\":\"canary\"}
EOF"
  ok "matrix canary at $pct% on argismonitor-app-canary; main on argismonitor-app"
  log "monitor SLOs for 15m before bumping with: proccompose matrix full"
}

cmd_matrix_canary_teardown() {
  log "tearing down canary deployment..."
  for proj in argismonitor-app-canary argismonitor-app; do
    vercel env rm OMNI_CANARY_PCT production --yes --scope $proj >/dev/null 2>&1 || true
    echo "0" | vercel env add OMNI_CANARY_PCT production --scope $proj >/dev/null
  done
  $PHENO_BIN run "cat > ${DATA_DIR}/matrix-state.json <<EOF
{\"canary_pct\":0,\"main_pct\":100,\"ts\":$(date +%s),\"action\":\"teardown\"}
EOF"
  ok "canary torn down"
}


#!/usr/bin/env sh
# .husky/pre-push — DEBT-002 fix (2026-06-25)
#
# Previously this was a no-op with a TODO to "Move to lefthook + cargo make
# at the repo root." Now it delegates to lefthook so the full pre-push
# matrix (typecheck-core, t11-budget, cycles) actually runs locally
# before pushing.

if command -v bunx >/dev/null 2>&1 && bunx --no-install lefthook --version >/dev/null 2>&1; then
  echo "→ lefthook pre-push (DEBT-002 fixed)"
  bunx lefthook run pre-push
  exit $?
fi

if command -v lefthook >/dev/null 2>&1; then
  echo "→ lefthook pre-push (DEBT-002 fixed, via PATH)"
  lefthook run pre-push
  exit $?
fi

echo "⚠️  lefthook not installed — skipping pre-push gate"
echo "   For full coverage run: bunx lefthook install"
echo "   CI (.github/workflows/audit-ratchet.yml) runs the full matrix anyway."
exit 0
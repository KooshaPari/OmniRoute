{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "argismonitor",
  "version": "4.0.0",
  "identifier": "local.argismonitor.app",
  "build": {
    "beforeDevCommand": "pnpm --filter web dev",
    "beforeBuildCommand": "pnpm --filter web build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../web/build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "argismonitor",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "url": "$WEB_URL"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost ws://localhost:5173 http://localhost:5173"
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "argismonitor — LLM router + combo dispatcher",
    "longDescription": "argismonitor: route LLM requests across providers with fallback combos, quota tracking, and a unified dashboard.",
    "macOS": {
      "minimumSystemVersion": "13.0",
      "frameworks": [],
      "providerShortName": null
    },
    "windows": {
      "wix": { "language": "en-US" }
    },
    "linux": {
      "deb": { "depends": [] }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": ["https://releases.argismonitor.local/{{target}}/{{arch}}/{{current_version}}"]
    }
  }
}

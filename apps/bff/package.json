{
  "name": "@argismonitor/bff",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": "1.3.14"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "benchmark:latency": "bun scripts/benchmark-latency.ts",
    "benchmark:compare": "bun scripts/compare-latency-runs.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "typecheck:ts7": "bun node_modules/typescript-7/bin/tsc --noEmit"
  },
  "dependencies": {
    "@argismonitor/api-contracts": "file:../../packages/api-contracts",
    "hono": "^4.0.0",
    "@hono/zod-validator": "^0.4.0",
    "@hono/node-server": "^1.0.0",
    "zod": "^4.0.0",
    "@hono/trpc-server": "^0.1.0",
    "@trpc/server": "^11.0.0",
    "msgpackr": "^1.11.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "typescript-7": "npm:typescript@7.0.2",
    "vitest": "^2.0.0"
  }
}

{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "argismonitor dashboard (SvelteKit 2 + Svelte 5 runes + Hono 4)",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node build/index.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:component": "vitest run tests/component",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "lint": "oxlint src tests",
    "lint:fix": "oxlint src tests --fix",
    "format": "oxfmt src tests",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --threshold error",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@inlang/paraglide-js": "^2.20.0",
    "@omniroute/sdk-js": "workspace:*",
    "@omniroute/shared-types": "workspace:*",
    "@tanstack/svelte-query": "^6.1.0",
    "@xyflow/svelte": "^1.6.0",
    "arctic": "^3.7.0",
    "bits-ui": "^2.18.0",
    "codemirror": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/lang-python": "^6.1.6",
    "hono": "^4.6.0",
    "mode-watcher": "^1.0.0",
    "nanoid": "^5.0.9",
    "paneforge": "^1.0.0",
    "runed": "^0.30.0",
    "shadcn-svelte": "^1.3.0",
    "svelte-dnd-action": "^0.9.7",
    "tailwind-merge": "^2.5.5",
    "tailwind-variants": "^0.3.0",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.20.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "@typescript/native-preview": "^7.0.0-dev.20260704.1",
    "msw": "^2.14.0",
    "oxfmt": "^0.16.0",
    "oxlint": "^1.72.0",
    "svelte": "^5.20.0",
    "svelte-check": "^4.1.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^7.0.0",
    "vitest": "^4.1.0"
  }
}

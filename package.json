{
  "name": "omniroute-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "OmniRoute v4 frontend + native shell monorepo (Svelte 5 + Hono + Tauri 2 + Rust gateway)",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0",
    "bun": ">=1.3.0"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "concurrently -n gateway,web,desktop -c blue,green,magenta \"pnpm --filter @omniroute/gateway dev\" \"pnpm --filter web dev\" \"pnpm --filter desktop dev\"",
    "dev:web": "pnpm --filter web dev",
    "dev:desktop": "pnpm --filter desktop dev",
    "dev:gateway": "pnpm --filter @omniroute/gateway dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter web build",
    "build:desktop": "pnpm --filter desktop build",
    "build:packages": "pnpm -r --filter \"./packages/*\" build",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "test:e2e": "pnpm -r test:e2e",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "typecheck": "tsgo -b",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "size": "size-limit",
    "clean": "pnpm -r exec rm -rf node_modules dist .svelte-kit build .turbo && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.0",
    "oxfmt": "^0.16.0",
    "oxlint": "^1.72.0",
    "size-limit": "^11.1.6",
    "typescript": "^5.6.3",
    "@typescript/native-preview": "^7.0.0-dev.20260704.1"
  }
}

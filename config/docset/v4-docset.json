{
  "schemaVersion": 1,
  "docsetId": "omniroute-v4",
  "versionSource": "apps/web/package.json",
  "reviewedInputs": [
    "docs/public/QUICKSTART_V4.md"
  ],
  "excludedInputs": [
    "docs/audits/**",
    "docs/reports/**",
    "docs/research/**",
    "docs/sessions/**",
    "worklogs/**"
  ],
  "publication": {
    "deployable": false,
    "releaseAttachable": false,
    "reason": "Owner approval is required for the public product identity and canonical repository/documentation URLs before deployment or release attachment."
  },
  "releaseAttachment": {
    "mediaType": "application/gzip",
    "filenameTemplate": "omniroute-v4-docset-{version}.tar.gz",
    "requiredSidecars": [
      "omniroute-v4-docset-{version}.tar.gz.sha256",
      "omniroute-v4-docset-{version}.attachment.json"
    ]
  }
}

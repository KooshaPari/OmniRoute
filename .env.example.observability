# ─── OmniRoute Observability Stack Env Vars ─────────────────────────────
# PR-001..005b + PR-006. All variables are read at initTelemetry() time.
# To disable the stack entirely (default), set OTEL_SDK_DISABLED=true.

# ── Core on/off ─────────────────────────────────────────────────────────
OTEL_SDK_DISABLED=true

# ── Service identification ──────────────────────────────────────────────
# Resource attributes attached to every span / metric / log.
OTEL_SERVICE_NAME=omniroute
SERVICE_VERSION=3.8.34
DEPLOYMENT_ENVIRONMENT=development
OTEL_SERVICE_VERSION=3.8.34
OTEL_DEPLOYMENT_ENVIRONMENT=development
OMNIROUTE_VERSION=3.8.34
OMNIROUTE_PID=

# ── Resource attributes (free-form, comma-separated k=v) ───────────────
OTEL_RESOURCE_ATTRIBUTES=deployment.region=us-east-1,deployment.zone=us-east-1a

# ── OTLP exporter (HTTP/JSON by default) ────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.example.com
OTEL_EXPORTER_OTLP_PROTOCOL=http/json
OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer%20xxx
OTEL_EXPORTER_OTLP_TIMEOUT=10000
OTEL_EXPORTER_OTLP_COMPRESSION=gzip

# ── Batching & retry ────────────────────────────────────────────────────
OTEL_BSP_MAX_EXPORT_BATCH_SIZE=512
OTEL_BSP_MAX_QUEUE_SIZE=2048
OTEL_BSP_SCHEDULE_DELAY=5000
OTEL_BSP_EXPORT_TIMEOUT=30000
OTEL_BSP_MAX_RETRY_ATTEMPTS=5
OTEL_BSP_INITIAL_RETRY_DELAY=1000
OTEL_BSP_MAX_RETRY_DELAY=30000

# ── Metrics ─────────────────────────────────────────────────────────────
# Cardinality cap per metric per label (drop new values past this).
OMNIROUTE_METRICS_CARDINALITY_CAP=64
# /metrics scrape interval (milliseconds)
OMNIROUTE_METRICS_SCRAPE_INTERVAL_MS=15000

# ── Logs ────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_MODE=json

# ── W3C Trace Context (PR-006) ──────────────────────────────────────────
# Inject traceparent on outbound fetches even when telemetry is disabled.
OTEL_PROPAGATORS=tracecontext,baggage
# Header name override (default: traceparent). Set for legacy systems that
# read "x-traceparent" or AWS X-Amzn-Trace-Id.
OMNIROUTE_TRACE_HEADER_NAME=traceparent

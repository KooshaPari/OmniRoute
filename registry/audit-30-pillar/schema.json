{
  "schema": "30-pillar-audit",
  "version": "1.0.0",
  "authority": "phenotype-registry",
  "description": "30-pillar audit schema covering build, test, lint, governance, and observability dimensions. Max score: 40.",
  "pillars": [
    {"id": 1, "name": "Build pass", "weight": 2, "check": "cargo build, go build, npm run build"},
    {"id": 2, "name": "Unit tests", "weight": 3, "check": "cargo test, go test, npm test"},
    {"id": 3, "name": "Formatting", "weight": 2, "check": "cargo fmt, gofmt, prettier"},
    {"id": 4, "name": "Linting", "weight": 2, "check": "clippy, golangci-lint, eslint"},
    {"id": 5, "name": "Dependency audit", "weight": 1, "check": "cargo deny, npm audit, govulncheck"},
    {"id": 6, "name": "Documentation", "weight": 1, "check": "cargo doc, go doc, typedoc"},
    {"id": 7, "name": "Snapshot tests", "weight": 1, "check": "test -- snapshot"},
    {"id": 8, "name": "Fuzz tests", "weight": 1, "check": "fuzz targets"},
    {"id": 9, "name": "Code coverage >=85%", "weight": 2, "check": "llvm-cov, jest --coverage"},
    {"id": 10, "name": "Security audit", "weight": 1, "check": "cargo audit, bandit, npm audit"},
    {"id": 11, "name": "Benchmarks", "weight": 1, "check": "cargo bench, go test -bench"},
    {"id": 12, "name": "ADR presence", "weight": 1, "check": "docs/adr/"},
    {"id": 13, "name": "CONTRIBUTING.md", "weight": 1, "check": "existence"},
    {"id": 14, "name": "SECURITY.md", "weight": 1, "check": "existence"},
    {"id": 15, "name": "LICENSE", "weight": 1, "check": "existence"},
    {"id": 16, "name": "CHANGELOG.md", "weight": 1, "check": "existence"},
    {"id": 17, "name": "CI/CD pipeline", "weight": 2, "check": "GitHub Actions"},
    {"id": 18, "name": "Pre-commit hooks", "weight": 1, "check": ".pre-commit-config.yaml"},
    {"id": 19, "name": "Dependabot / Snyk", "weight": 1, "check": "dependency auto-update"},
    {"id": 20, "name": "AGENTS.md", "weight": 1, "check": "governance"},
    {"id": 21, "name": "CLAUDE.md", "weight": 1, "check": "prompt router"},
    {"id": 22, "name": "CODEOWNERS", "weight": 1, "check": "boundary ownership"},
    {"id": 23, "name": "deny.toml", "weight": 1, "check": "dependency allowlist"},
    {"id": 24, "name": "clippy.toml", "weight": 1, "check": "lint baseline"},
    {"id": 25, "name": "rust-toolchain.toml", "weight": 1, "check": "toolchain pin"},
    {"id": 26, "name": "Taskfile.yml", "weight": 1, "check": "task runner standard"},
    {"id": 27, "name": "E2E tests", "weight": 2, "check": "integration test suite"},
    {"id": 28, "name": "Mutation tests", "weight": 1, "check": "stryker, mutmut"},
    {"id": 29, "name": "Performance tests", "weight": 1, "check": "benchmark suite"},
    {"id": 30, "name": "OTEL observability", "weight": 1, "check": "OpenTelemetry integration"}
  ],
  "max_score": 40,
  "grade_boundaries": [
    {"min": 80.1, "max": 89, "grade": "8.0-8.9", "classification": "L4: Excellent"},
    {"min": 70.1, "max": 80, "grade": "7.0-7.9", "classification": "L3: On Track"},
    {"min": 50.1, "max": 70, "grade": "5.0-6.9", "classification": "L2: Needs Improvement"},
    {"min": 20.1, "max": 50, "grade": "2.0-4.9", "classification": "L1: Critical Foundation Needed"},
    {"min": 0, "max": 20, "grade": "0-1.9", "classification": "L0: Unacceptable"}
  ]
}

    {"id": "26-30", "name": "Release channel", "weight": 5, "description": "5-tier release governance present"},
    {"id": "31-35", "name": "Ecosystem map accuracy", "weight": 5, "description": "ECOSYSTEM_MAP.md reflects current state"},
    {"id": "36-37", "name": "Security policy", "weight": 2, "description": "SECURITY.md + policy"},
    {"id": 38, "name": "Code of conduct", "weight": 1, "description": "CODE_OF_CONDUCT.md"},


{
  "__inputs": [],
  "__requires": [],
  "title": "Dispatch Binding Tiers — ADR-032",
  "uid": "dispatch-tiers",
  "panels": [
    {
      "title": "Current tier breakdown (gauge)",
      "type": "stat",
      "targets": [
        {
          "expr": "dispatch:current_tiers:count",
          "legendFormat": "T{{le}}"
        }
      ],
      "description": "Number of dispatch edges running on each tier right now"
    },
    {
      "title": "Tier adoption ratio (time series)",
      "type": "graph",
      "targets": [
        {
          "expr": "dispatch:tier_adoption_ratio",
          "legendFormat": "T2+T3 / total edges"
        }
      ],
      "description": "Fraction of edges running on T2 or T3 (target >0.90)"
    },
    {
      "title": "Tier changes per 5m (bar chart)",
      "type": "bargauge",
      "targets": [
        {
          "expr": "dispatch:tier_changes:rate5m",
          "legendFormat": "T{{old_tier}}→T{{new_tier}}: {{reason}}"
        }
      ],
      "description": "How often edges change tier, broken down by transition"
    },
    {
      "title": "Reconcile sweep p95 (histogram)",
      "type": "heatmap",
      "targets": [
        {
          "expr": "dispatch:sweep_duration:quantile_over_1h"
        }
      ],
      "description": "P95 duration of reconciler tick, in seconds"
    }
  ],
  "annotations": {
    "list": [
      {
        "datasource": "Prometheus",
        "expr": "dispatch:tier_changes:rate5m > 0.1",
        "title": "Tier cascade event",
        "tagColor": "red"
      }
    ]
  },
  "editable": true,
  "schemaVersion": 39
}
